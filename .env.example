# ═══ إعدادات درب التبانة الجامعي ═══
# انسخ هذا الملف إلى .env واملأ القيم

# Supabase (من: supabase.com → مشروعك → Settings → API)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
# مفتاح الخدمة (للكتابة من الخادم — سرّي جداً، لا تشاركه)
SUPABASE_SERVICE_KEY=eyJhbGc...

# سرّ توقيع جلسات الأدمن (غيّره لأي نص عشوائي طويل)
JWT_SECRET=change-this-to-a-long-random-string-2026

# المنفذ
PORT=3000
