{
  "version": 2,
  "builds": [
    { "src": "server/index.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/index.js" },
    { "src": "/(css|js)/(.*)", "dest": "/public/$1/$2" },
    { "src": "/(departments|department|universities|university)", "dest": "server/index.js" },
    { "src": "/", "dest": "server/index.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
